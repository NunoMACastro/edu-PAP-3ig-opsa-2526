# OPSA — demo académica local
# O setup copia este ficheiro para `.env` quando necessário. As credenciais
# PostgreSQL abaixo pertencem ao Compose local e não devem ser alteradas.
NODE_ENV=development
PORT=3000
APP_BASE_URL=http://localhost:5173
DATABASE_URL=postgresql://opsa_app:opsa-local-postgres-2026@127.0.0.1:5433/opsa_dev

# Providers da demo: sem Redis, S3 ou SMTP reais. O rate limiter local protege
# autenticação num único processo e o email permanece observável na outbox.
REDIS_PROVIDER=local
STORAGE_PROVIDER=local
EMAIL_PROVIDER=simulated
REDIS_KEY_PREFIX=opsa:development
RATE_LIMIT_HMAC_KEY=development-only-rate-limit-key-32-bytes

# O chat de IA faz parte da demo; quotas distribuídas não são prometidas neste
# perfil e o backend responde pelo motor determinístico local.
AI_CHAT_ENABLED=true
AI_PROVIDER_MODE=disabled
AI_CHAT_ENCRYPTION_KEY=AgICAgICAgICAgICAgICAgICAgICAgICAgICAgICAgI=
AI_SAFETY_HMAC_KEY=development-only-ai-safety-key-32-bytes

# Outbox cifrada e storage privado local.
EMAIL_OUTBOX_ENCRYPTION_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=
# Código mantido apenas em memória pelo browser para abrir a inbox local.
DEMO_EMAIL_INBOX_ACCESS_KEY=opsa-demo-2026
OPSA_PRIVATE_STORAGE_ROOT=./private-storage

# Funcionalidades opcionais — manter comentadas na demo normal.
# Injetar por ambiente/secret manager quando o provider externo for necessário.
# OPENAI_API_KEY=
# OPENAI_MODEL=
# SMTP_HOST=smtp.example.invalid
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_REQUIRE_TLS=true
# EMAIL_FROM="OPSA <no-reply@example.invalid>"
# SMTP_USER=<injetar-por-canal-seguro>
# SMTP_PASSWORD=<injetar-por-canal-seguro>
# A demo gera XML explicitamente não certificado, sem fingir XSD/revisão externa.
SAFT_EXPORT_ENABLED=true
SAFT_VALIDATION_MODE=academic
# No modo external, configurar também:
# SAFT_XSD_PATH=/caminho/privado/SAFTPT1.04_01.xsd

# Backup/restore académico local, executado manualmente. O destino de restore
# tem de ser outra base explicitamente descartável; nunca reutilizar DATABASE_URL.
OPSA_BACKUP_MODE=local
OPSA_BACKUP_DIR=./private-storage/backups
RESTORE_DATABASE_URL=postgresql://opsa_app:opsa-local-postgres-2026@127.0.0.1:5435/opsa_restore_test
OPSA_POSTGRES_CLI_MODE=compose

# Production-like (NODE_ENV=production): configurar por ambiente/secret manager,
# nunca copiar as chaves demonstrativas acima. O arranque exige HTTPS, PostgreSQL,
# Redis, chaves próprias, SMTP com TLS e S3 completo com SSE.
# REDIS_PROVIDER=redis
# STORAGE_PROVIDER=s3
# EMAIL_PROVIDER=smtp
# REDIS_URL=rediss://redis.example.invalid:6379
# S3_ENDPOINT=https://objects.example.invalid
# S3_REGION=eu-west-1
# S3_BUCKET=opsa-private
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_FORCE_PATH_STYLE=false
# S3_SSE=AES256
# BACKUP_S3_BUCKET=opsa-private-backups
# BACKUP_S3_PREFIX=backups
# BACKUP_RETENTION_DAYS=30
