NODE_ENV=development
PORT=3000
APP_BASE_URL=http://localhost:5173
DATABASE_URL=postgresql://user:password@localhost:5432/opsa_dev
# Serviços remotos dedicados ao gate; nunca reutilizar dados de produção.
TEST_DATABASE_URL=postgresql://user:password@test-db.example.invalid:5432/opsa_test
RESTORE_DATABASE_URL=postgresql://user:password@test-db.example.invalid:5432/opsa_restore_test
OPSA_PRIVATE_STORAGE_ROOT=./private-storage
SAFT_EXPORT_ENABLED=false
# SAFT_XSD_PATH=/secure/path/to/SAFTPT1.04_01.xsd
TRUST_PROXY_HOPS=0
REDIS_URL=redis://127.0.0.1:6379
REDIS_KEY_PREFIX=opsa:development
RATE_LIMIT_HMAC_KEY=development-only-rate-limit-key-32-bytes
EMAIL_OUTBOX_ENCRYPTION_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=
NOTIFICATION_WORKER_INTERVAL_MS=300000

# IA externa é opt-in e fica desligada por omissão. A chave nunca vai para o web.
AI_CHAT_ENABLED=true
AI_PROVIDER_MODE=disabled
# OPENAI_API_KEY deve ser injetada pelo secret manager quando o provider estiver ativo.
OPENAI_API_KEY=
# Obrigatório apenas quando AI_PROVIDER_MODE=openai.
OPENAI_MODEL=
OPENAI_TIMEOUT_MS=20000
OPENAI_MAX_OUTPUT_TOKENS=800
AI_USER_DAILY_TURN_LIMIT=50
AI_COMPANY_DAILY_TURN_LIMIT=500
AI_CHAT_RETENTION_DAYS=90
AI_WORKER_INTERVAL_MS=3600000
AI_WORKER_POLL_INTERVAL_MS=5000
AI_WORKER_LEASE_MS=300000
AI_WORKER_MAX_ATTEMPTS=3
AI_WORKER_BATCH_SIZE=10
# Deve ser uma chave AES-256 própria, diferente da chave da outbox de email.
AI_CHAT_ENCRYPTION_KEY=AgICAgICAgICAgICAgICAgICAgICAgICAgICAgICAgI=
# HMAC sem email/username para safety_identifier; em produção usar segredo próprio.
AI_SAFETY_HMAC_KEY=development-only-ai-safety-key-32-bytes
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_REQUIRE_TLS=false
EMAIL_FROM="OPSA <no-reply@opsa.local>"
# SMTP_USER=
# SMTP_PASSWORD=

# S3 compatível. Fora de development não existe fallback local.
S3_ENDPOINT=https://s3.example.invalid
S3_REGION=eu-west-1
S3_BUCKET=opsa-academic-test
S3_ACCESS_KEY_ID=replace-via-secure-channel
S3_SECRET_ACCESS_KEY=replace-via-secure-channel
S3_FORCE_PATH_STYLE=false
S3_SSE=AES256
BACKUP_S3_BUCKET=opsa-academic-test-backups
BACKUP_S3_PREFIX=backups
BACKUP_RETENTION_DAYS=30
# Restauro isolado posterior: copiar do output do backup por canal seguro.
# OPSA_BACKUP_MANIFEST_KEY=backups/2026-07-09T00-00-00.000Z/manifest.json
# OPSA_BACKUP_MANIFEST_SHA256=<sha256-do-manifesto>

# O exportador permanece fail-closed até XSD 1.1, reconciliação e revisão externa.
SAFT_EXPORT_ENABLED=false
SAFT_XSD_PATH=/secure/path/to/saftpt1.04_01.xsd

# Produção exige Redis, chaves próprias, SMTP real/TLS e S3 com SSE.
