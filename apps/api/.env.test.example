# PostgreSQL local descartável em Docker Compose. Este bloco basta para os
# testes de persistência, concorrência, migrations e seeds locais.
TEST_DATABASE_URL=postgresql://opsa_app:opsa-local-postgres-2026@127.0.0.1:5434/opsa_test_ci
RESTORE_DATABASE_URL=postgresql://opsa_app:opsa-local-postgres-2026@127.0.0.1:5435/opsa_restore_test
OPSA_POSTGRES_CLI_MODE=compose
OPSA_SKIP_PERSISTENCE_TESTS=false

# Gates externos deliberadamente separados. Não são necessários para
# `test:integration:postgres-local` e não têm fallback para Docker local.
REDIS_PROVIDER=redis
STORAGE_PROVIDER=s3
EMAIL_PROVIDER=smtp
REDIS_URL=redis://127.0.0.1:6379
REDIS_KEY_PREFIX=opsa:test
RATE_LIMIT_HMAC_KEY=replace-with-a-test-only-key-of-at-least-32-bytes

# SMTP sandbox dedicado.
SMTP_HOST=smtp-sandbox.example.invalid
SMTP_PORT=587
SMTP_SECURE=false
SMTP_REQUIRE_TLS=true
SMTP_USER=replace-via-secure-channel
SMTP_PASSWORD=replace-via-secure-channel
EMAIL_FROM=OPSA Academic <no-reply@example.invalid>
EMAIL_OUTBOX_ENCRYPTION_KEY=replace-with-32-byte-base64-key
DEMO_EMAIL_INBOX_ACCESS_KEY=replace-with-demo-inbox-code
NOTIFICATION_WORKER_INTERVAL_MS=300000

# Object storage e bucket de backup exclusivamente de teste.
S3_ENDPOINT=https://s3.example.invalid
S3_REGION=eu-west-1
S3_BUCKET=opsa-academic-test
S3_ACCESS_KEY_ID=replace-via-secure-channel
S3_SECRET_ACCESS_KEY=replace-via-secure-channel
S3_FORCE_PATH_STYLE=false
S3_SSE=AES256
BACKUP_S3_BUCKET=opsa-academic-test-backups
BACKUP_S3_PREFIX=backups
BACKUP_RETENTION_DAYS=30

SAFT_EXPORT_ENABLED=false
SAFT_VALIDATION_MODE=external
SAFT_XSD_PATH=/secure/path/to/saftpt1.04_01.xsd

# Smoke autenticado opcional de concorrencia MF6.
OPSA_API_BASE_URL=http://127.0.0.1:3000
OPSA_CONCURRENCY_PATHS=/api/customers,/api/items
# Deve conter pelo menos 25 cookies de sessao quando o smoke HTTP for usado.
# OPSA_SESSION_COOKIES_JSON=["sid=session-cookie-1","sid=session-cookie-2"]
