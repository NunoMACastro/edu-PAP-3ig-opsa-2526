{
  "name": "@opsa/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.6.2",
  "engines": {
    "node": ">=24.17 <25",
    "npm": ">=11 <12"
  },
  "description": "API OPSA para os BKs MF0, seguindo o contrato apps/api definido na planificação.",
  "main": "src/server.js",
  "scripts": {
    "dev": "node src/server.js",
    "config:check": "node scripts/check-local-config.mjs",
    "demo:check": "npm run config:check",
    "health:deep-check": "node scripts/run-readiness-deep-diagnostic.mjs",
    "prisma:generate": "prisma generate",
    "prisma:validate": "prisma validate",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:local:check": "node scripts/local-postgres.mjs check --target=local",
    "db:local:start": "node scripts/local-postgres.mjs start --target=local",
    "db:local:status": "node scripts/local-postgres.mjs status --target=local",
    "db:local:logs": "node scripts/local-postgres.mjs logs --target=local",
    "db:local:setup": "node scripts/local-postgres.mjs setup --target=local",
    "db:local:stop": "node scripts/local-postgres.mjs stop --target=local",
    "db:local:reset": "node scripts/local-postgres.mjs reset --target=local",
    "db:test:start": "node scripts/local-postgres.mjs start --target=test",
    "db:test:reset": "node scripts/local-postgres.mjs reset --target=test",
    "db:test:stop": "node scripts/local-postgres.mjs stop --target=test",
    "db:restore:start": "node scripts/local-postgres.mjs start --target=restore",
    "db:restore:reset": "node scripts/local-postgres.mjs reset --target=restore",
    "db:restore:stop": "node scripts/local-postgres.mjs stop --target=restore",
    "db:seed": "node prisma/seed.js --profile demo",
    "db:seed:demo": "node prisma/seed.js --profile demo",
    "db:seed:load": "node prisma/seed.js --profile load",
    "db:seed:verify": "node prisma/seed.js --profile verify --target demo",
    "db:seed:verify:load": "node prisma/seed.js --profile verify --target load",
    "migration:precheck-mf0": "node scripts/precheck-mf0-migration.js",
    "migration:assert-empty-test-db": "node scripts/assert-empty-test-database.mjs",
    "syntax:check": "find src tests scripts -type f \\( -name '*.js' -o -name '*.mjs' \\) -print0 | xargs -0 -n 1 node --check",
    "test": "npm run test:unit && npm run test:contracts",
    "test:unit": "node --test tests/unit/*.test.js",
    "test:contracts": "node --test tests/contracts/*.test.js",
    "test:mf8:subscriptions": "node --test tests/contracts/mf8-subscriptions.contract.test.js",
    "test:mf8:ai-explainability": "node --test tests/contracts/mf8-ai-explainability.contract.test.js",
    "test:mf8:ai-governance": "node --test tests/contracts/mf8-ai-governance.contract.test.js",
    "test:mf8:technical-docs": "node scripts/check-mf8-technical-docs.mjs",
    "test:mf8": "npm run test:mf8:subscriptions && npm run test:mf8:ai-explainability && npm run test:mf8:ai-governance && npm run test:mf8:technical-docs",
    "test:integration:postgres-local": "node scripts/run-postgres-local-integration.mjs",
    "test:integration:external": "node --test --test-concurrency=1 tests/integration/auth-onboarding-email-persistence.test.js tests/integration/redis-rate-limit.test.js",
    "test:integration": "npm run test:integration:postgres-local && npm run test:integration:external",
    "test:seed:integration": "node --test tests/seed/*.test.js",
    "test:mf6:documents": "node scripts/check-mf6-document-performance.mjs",
    "test:mf6:concurrency": "node scripts/check-mf6-concurrency.mjs",
    "test:mf6:reconciliation": "node scripts/check-mf6-reconciliation-performance.mjs",
    "test:mf6:fifo": "node scripts/check-mf6-fifo-performance.mjs",
    "test:mf6:https": "node scripts/check-mf6-https.mjs",
    "test:mf6:bcrypt": "node scripts/check-mf6-bcrypt.mjs",
    "test:mf6:session-cookie": "node scripts/check-mf6-session-cookie.mjs",
    "test:mf6:hardening": "node scripts/check-mf6-hardening.mjs",
    "test:mf6:env": "node scripts/check-mf6-env.mjs",
    "test:mf6:audit": "node scripts/check-mf6-audit-gate.mjs",
    "test:mf6": "npm run test:mf6:documents && npm run test:mf6:concurrency && npm run test:mf6:reconciliation && npm run test:mf6:fifo && npm run test:mf6:https && npm run test:mf6:bcrypt && npm run test:mf6:session-cookie && npm run test:mf6:hardening && npm run test:mf6:env && npm run test:mf6:audit",
    "mf7:backup": "node scripts/run-daily-backup.mjs",
    "mf7:backup:verify": "node scripts/verify-backup-restore.mjs",
    "mf7:backup:roundtrip": "node scripts/run-backup-roundtrip.mjs",
    "mf7:backup:remote": "node scripts/run-daily-backup.mjs --remote",
    "mf7:backup:verify:remote": "node scripts/verify-backup-restore.mjs --remote",
    "mf7:backup:roundtrip:remote": "node scripts/run-backup-roundtrip.mjs --remote",
    "retention:backfill": "node scripts/backfill-retention-holds.mjs",
    "worker:email": "node scripts/run-email-outbox-worker.mjs",
    "worker:email:drain": "node scripts/run-email-outbox-worker.mjs --drain",
    "worker:notifications": "node scripts/run-notification-worker.mjs",
    "worker:notifications:drain": "node scripts/run-notification-worker.mjs --drain",
    "worker:ai": "node scripts/run-ai-analysis-worker.mjs",
    "worker:ai:drain": "node scripts/run-ai-analysis-worker.mjs --drain",
    "ai:compact-aliases": "node scripts/compact-ai-alias-maps.mjs",
    "gate:academic:report": "node scripts/check-academic-report-state.mjs",
    "gate:academic": "node scripts/run-academic-release-gate.mjs",
    "test:mf7:retention": "node --test tests/unit/retentionPolicy.test.js",
    "test:mf7:email": "node --test tests/contracts/mf7-email-contracts.test.js",
    "test:mf7:exports": "node --test tests/contracts/mf7-export-contracts.test.js",
    "test:mf7:imports": "node --test tests/contracts/mf7-import-contracts.test.js",
    "test:mf7:saft": "node --test tests/contracts/mf7-saft-contracts.test.js",
    "check:mf7:backend-modules": "node scripts/check-mf7-backend-modules.mjs",
    "test:mf7:critical-modules": "node --test tests/contracts/mf7-critical-modules.test.js",
    "test:mf7": "npm run test:mf7:retention && npm run test:mf7:email && npm run test:mf7:exports && npm run test:mf7:imports && npm run test:mf7:saft && npm run check:mf7:backend-modules && npm run test:mf7:critical-modules",
    "test:final:prepare": "npm run syntax:check && npm run test:unit && npm run test:contracts && npm run test:integration && npm run test:seed:integration && npm run test:mf6 && npm run test:mf7 && npm run test:mf8",
    "mf8:final-validation": "node scripts/run-mf8-final-validation.mjs",
    "mf8:defect-report": "node scripts/check-mf8-defect-report.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1084.0",
    "@prisma/client": "^6.19.3",
    "bcrypt": "^6.0.0",
    "busboy": "^1.6.0",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "iconv-lite": "^0.7.3",
    "nodemailer": "^9.0.3",
    "openai": "6.46.0",
    "pdfkit": "^0.15.2",
    "redis": "^6.1.0",
    "xmlbuilder2": "^4.0.3"
  },
  "devDependencies": {
    "prisma": "^6.19.3",
    "supertest": "^7.2.2"
  },
  "prisma": {
    "seed": "node prisma/seed.js --profile demo"
  },
  "overrides": {
    "uuid": "11.1.1"
  }
}
