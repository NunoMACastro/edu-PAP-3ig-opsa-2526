{
  "name": "@opsa/web",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Frontend MF0 da OPSA em React, Vite e TypeScript.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "test:mf1": "node scripts/check-mf1-contracts.mjs",
    "test:mf2": "node scripts/check-mf2-workflows.mjs",
    "test:mf3": "node scripts/check-mf3-evidence.mjs",
    "test:mf5:forms": "node scripts/check-mf5-form-validation.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.9.3",
    "vite": "^8.0.14"
  }
}