import { PrismaClient } from "@prisma/client";
import {
  validateWarehouse,
  validateLocation
} from "./validators.js";

const prisma = new PrismaClient();

/**
 * Lista todos os armazéns da empresa
 */
export async function findAll(companyId) {
  return prisma.warehouse.findMany({
    where: { companyId },
    include: {
      locations: true
    }
  });
}

/**
 * Cria um novo armazém
 */
export async function create(data, companyId) {
  validateWarehouse(data);

  return prisma.warehouse.create({
    data: {
      code: data.code,
      name: data.name,
      companyId
    }
  });
}

/**
 * Cria uma localização num armazém
 */
export async function createLocation(
  warehouseId,
  data
) {
  validateLocation(data);

  // Verifica se já existe uma localização com o mesmo código
  const existing =
    await prisma.warehouseLocation.findFirst({
      where: {
        warehouseId,
        code: data.code
      }
    });

  if (existing) {
    throw new Error(
      "Já existe uma localização com esse código"
    );
  }

  return prisma.warehouseLocation.create({
    data: {
      warehouseId,
      code: data.code
    }
  });
}