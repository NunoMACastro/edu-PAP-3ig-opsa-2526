// Ligação à base de dados
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Cliente Prisma
generator client {
  provider = "prisma-client-js"
}

// Armazém
model Warehouse {
  id          String              @id @default(cuid())
  code        String              @unique
  name        String
  companyId   String

  // Relação com localizações
  locations   WarehouseLocation[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Localização dentro do armazém
model WarehouseLocation {
  id          String    @id @default(cuid())
  warehouseId String
  code        String

  // Relação com o armazém
  warehouse Warehouse @relation(
    fields: [warehouseId],
    references: [id]
  )

  // Não permite códigos repetidos no mesmo armazém
  @@unique([warehouseId, code])
}
